# Environment Variables Template
# Copy this to .env.local (development) or configure in deployment platform
# NEVER commit actual .env file to git!

# ===== SERVER =====
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:5001

# ===== DATABASE (PostgreSQL) =====
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=socialsense

# Preferred in production (Supabase/Neon/Vercel Storage)
# DATABASE_URL=postgresql://user:pass@host:port/db?sslmode=require

# Vercel Storage (Supabase integration can expose these names)
# POSTGRES_URL=postgres://...
# POSTGRES_PRISMA_URL=postgres://...
# POSTGRES_URL_NON_POOLING=postgres://...

# Supabase public keys (frontend-safe)
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# ===== LLM APIS =====
# Claude API for sentiment analysis and chat copilot
# Get from: https://console.anthropic.com/account/keys
CLAUDE_API_KEY=sk-ant-

# News API for news aggregation
# Get from: https://newsapi.org/
NEWSAPI_KEY=

# ===== EXTERNAL SERVICES =====
# Sentry for error tracking
SENTRY_DSN=

# Email configuration (if sending transactional emails)
# Using Zoho SMTP
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=hello@socialsense.io
SMTP_PASSWORD=
SMTP_FROM=hello@socialsense.io

# ===== DEPLOYMENT PLATFORMS =====
# Vercel (frontend hosting)
# VERCEL_URL=https://socialsense.io

# Railway (backend hosting - auto-provided)
# RAILWAY_ENVIRONMENT_NAME=production

# ===== DOMAIN & EMAIL =====
DOMAIN=socialsense.io
EMAIL=hello@socialsense.io

# ===== SECURITY =====
JWT_SECRET=your-super-secret-key-change-this-in-production
CORS_ORIGIN=http://localhost:3000,https://socialsense.io

# ===== FEATURE FLAGS =====
ENABLE_GEOGRAPHIC_ANALYSIS=true
ENABLE_CHAT_COPILOT=true
ENABLE_NEWS_AGGREGATION=true

# ===== RATE LIMITING =====
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=100
CLAUDE_API_RATE_LIMIT=10

# ===== LOGGING =====
LOG_LEVEL=debug
